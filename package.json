  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexHerranr/whapi-agent.git"
  },
  "bugs": {
    "url": "https://github.com/AlexHerranr/whapi-agent/issues"
  },
  "homepage": "https://github.com/AlexHerranr/whapi-agent#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "better-sqlite3": "^12.0.0",
