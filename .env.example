# ── Required ──────────────────────────────────────────────────────────

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-5

# WHAPI.cloud token — https://whapi.cloud
WHAPI_TOKEN=

# WHAPI.cloud base URL
WHAPI_API_URL=https://gate.whapi.cloud

# ── Optional ──────────────────────────────────────────────────────────

# Port for the webhook server
PORT=3000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Message buffer window in milliseconds (groups rapid messages)
BUFFER_WINDOW_MS=3000

# Max messages kept per conversation context
HISTORY_MAX_MESSAGES=30

# SQLite database file path
SQLITE_PATH=./data/whapi-agent.sqlite

# Rate limit: max messages per minute per chat
RATE_LIMIT_PER_MINUTE=30
